<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">

    <title>CV</title>
</head>

<body>
    <!--Header med huvudrubrik och navigation-->
    <%- include("partials/header"); %>

        <main>
            <section>
                <h2>Kurser</h2>

                <!--Kontroll för om kurs är inlagd-->
                <% if (courses.length===0) { %>
                    <p>Inga kurser inlagda ännu</p>
                    <% } else { %>

                        <!--Finns kurs loopas dessa igenom och skrivs ut i lista-->
                        <% courses.forEach(course=> { %>

                            <div class="coursecard">
                                <h3 class="coursecode">
                                    <%= course.coursecode %>
                                </h3>

                                <p class="coursename">
                                    <%= course.coursename %>
                                </p>

                                <span class="courseprogression">
                                    Progression: <%= course.progression %>
                                </span><br>

                                <a class="coursesyllabus" href="<%= course.syllabus %>" target="_blank">Kursplan</a>
                                </>
                            </div>

                            <% }) %>


                                <% } %>

            </section>
        </main>

</body>

</html>